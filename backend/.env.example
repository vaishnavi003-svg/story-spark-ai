# MongoDB connection string (local or Atlas)
DATABASE_URL=mongodb://127.0.0.1:27017/story_spark_ai

# Server
PORT=5000
NODE_ENV=development

# Optional: comma-separated frontend origins for CORS (e.g. http://localhost:4001)
# CORS_ORIGINS=http://localhost:4001

# Auth
SALT_ROUNDS=10
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_EXPIRES_IN=60d
JWT_REFRESH_EXPIRES_IN=120d
DEFAULT_ADMIN_PASSWORD=change-me

# AI story generation (at least one provider is typically required)
OPEN_AI_KEY=
GEMINI_API_KEY= 
# Cover images (Unsplash)
UNSPLASH_KEY_API=
UNSPLASH_KEY_API_SECRET=

# Email verification (e.g. Gmail app password)
VERIFY_EMAIL=
VERIFY_PASSWORD=

# Google OAuth (Get from Google Cloud Console)
GOOGLE_CLIENT_ID=355661960799-ivrdskmtvl8tngeoqpshaemnitgh5n2v.apps.googleusercontent.com
